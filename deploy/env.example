ERPNEXT_VERSION=v15.89.0
FRAPPE_VERSION=v15.89.0

# Custom image built on the server
CUSTOM_IMAGE=ogx-erp
CUSTOM_TAG=v15
PULL_POLICY=never

# Site / TLS
SITES=`erp.ogxstudio.in`
LETSENCRYPT_EMAIL=hello@ogxstudio.in

# Database (MariaDB root — set a strong password before deploy)
DB_PASSWORD=CHANGE_ME_DB_ROOT_PASSWORD

# HTTP basic auth for Traefik dashboard (optional)
# HASHED_PASSWORD=

# Used by site creation script
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
